
#############################################
# TARGET POSTGRESQL RUNTIME (.env / .env.local)
#############################################

# Preferred single-string connection option
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/lifeline

# Or use standard PG variables
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=lifeline
PGSSL=0
PGSSL_ALLOW_SELF_SIGNED=1
DB_WAIT_TIMEOUT_MS=60000
DB_WAIT_INTERVAL_MS=2000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:3000
APP_ORIGIN=http://localhost:3000

# Server Configuration
PORT=3000
NODE_ENV=development

# TypeORM / Logging
TYPEORM_LOGGING=1
LOG_LEVEL=debug

# Local auth bypass for development and verification only
AUTH_DISABLED=0
AUTH_LOCAL_USER_ID=guest-local

# Auth0 Configuration
AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_ISSUER=your-auth0-issuer

