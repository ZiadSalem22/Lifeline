#############################################
# PRODUCTION ENVIRONMENT (.env example)
#############################################

# Public/Auth0 browser origin: https://lifeline.a2z-us.com

VITE_AUTH_DISABLED=0
VITE_AUTH0_DOMAIN=your-auth0-domain
VITE_AUTH0_CLIENT_ID=your-production-client-id
VITE_AUTH0_AUDIENCE=your-auth0-audience
VITE_AUTH0_SCOPE=openid profile email offline_access
VITE_API_BASE_URL=/
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_TENANT_ID=your-azure-tenant-id

#############################################
# LOCAL DEVELOPMENT ENVIRONMENT (.env.local example)
#############################################

# Public/Auth0 browser origin: http://localhost:3020

VITE_AUTH_DISABLED=0
VITE_AUTH0_DOMAIN=your-auth0-domain
VITE_AUTH0_CLIENT_ID=your-local-client-id
VITE_AUTH0_AUDIENCE=your-auth0-audience
VITE_AUTH0_SCOPE=openid profile email offline_access
VITE_API_BASE_URL=http://localhost:3000

#############################################
# LOCAL COMPOSE VERIFICATION (.env.compose example)
#############################################

# Pair with backend AUTH_DISABLED=1 for local container verification.
# Public/browser app origin: http://localhost:3020
VITE_AUTH_DISABLED=1
VITE_API_BASE_URL=/
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_TENANT_ID=your-azure-tenant-id
