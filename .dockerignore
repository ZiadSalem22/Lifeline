# Build context for the root Dockerfile (the new TypeScript monorepo).
# Keep the context lean: exclude VCS, dev artifacts, and the legacy app dirs
# that linger for one cutover cycle but are NOT part of the new image.

.git
.github
.vscode
.agent
.claude

**/node_modules
**/dist
**/coverage
**/.nyc_output
**/.vite
**/.cache

**/.env
**/.env.*
!**/.env.example

*.log
*.tmp

# Compose files are not needed inside the image build context
compose*.yaml

# Ops + docs: shipped to the VPS via `git archive` but NOT needed inside the
# image, so they stay out of the build context. deploy/ is load-bearing on the
# VPS (apply-release.sh + the nginx vhost) — exclude it here, never delete it.
deploy/
docs/
