APP_PORT=3020
MCP_PORT=3030

POSTGRES_DB=lifeline
POSTGRES_USER=lifeline
POSTGRES_PASSWORD=change-me
MCP_API_KEY_PEPPER=change-me
MCP_INTERNAL_SHARED_SECRET=change-me

PGSSL=0
PGSSL_ALLOW_SELF_SIGNED=1
DB_WAIT_TIMEOUT_MS=60000
DB_WAIT_INTERVAL_MS=2000
TYPEORM_LOGGING=0
LOG_LEVEL=info
MCP_LOG_LEVEL=info
MCP_REQUEST_TIMEOUT_MS=5000

AUTH_DISABLED=0
AUTH_LOCAL_USER_ID=guest-local

AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_AUDIENCE_ALT=
AUTH0_ISSUER=https://your-auth0-domain/

# MCP Auth0/OAuth settings.
# Leave MCP_AUTH0_DOMAIN / AUDIENCE / ISSUER blank to reuse the shared AUTH0_* values above.
# If MCP should use a different Auth0 tenant or API than the main app, set both
# MCP_AUTH0_ISSUER and the matching MCP_AUTH0_DOMAIN / MCP_AUTH0_AUDIENCE values.
# Recommended production scopes mirror the MCP tool-layer scopes.
MCP_AUTH0_DOMAIN=
MCP_AUTH0_AUDIENCE=
MCP_AUTH0_AUDIENCE_ALT=
MCP_AUTH0_ISSUER=
MCP_AUTH0_SUPPORTED_SCOPES=tasks:read,tasks:write
MCP_AUTH0_REGISTRATION_ENDPOINT=
MCP_AUTH0_REVOCATION_ENDPOINT=
MCP_AUTH0_RESOURCE_NAME=Lifeline MCP
MCP_AUTH0_SERVICE_DOCUMENTATION_URL=

VITE_AUTH_DISABLED=0
VITE_API_BASE_URL=/
VITE_AUTH0_DOMAIN=your-auth0-domain
VITE_AUTH0_CLIENT_ID=your-production-client-id
VITE_AUTH0_AUDIENCE=your-auth0-audience
VITE_AUTH0_SCOPE="openid profile email offline_access"

CORS_ORIGIN=https://lifeline.a2z-us.com
FRONTEND_ORIGIN=https://lifeline.a2z-us.com
APP_ORIGIN=https://lifeline.a2z-us.com

MCP_BIND_HOST=0.0.0.0
MCP_PUBLIC_BASE_URL=https://mcp.lifeline.a2z-us.com
MCP_ALLOWED_HOSTS=mcp.lifeline.a2z-us.com,127.0.0.1,localhost
LIFELINE_BACKEND_BASE_URL=http://lifeline-app:3000
