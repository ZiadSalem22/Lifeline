# ── Lifeline web client environment ─────────────────────────────────────────
# Copy to .env.local and fill in. All variables are optional in dev when
# VITE_AUTH_DISABLED=1 (local compose mode).

# Base URL of the API server. Empty string means same-origin (the Vite dev
# server proxies /api to the server, and production serves the SPA from the
# API itself). The client always appends `/api/v1`.
VITE_API_BASE_URL=

# ── Auth0 (required unless VITE_AUTH_DISABLED=1) ─────────────────────────────
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
# API identifier (audience) for access tokens. Optional but required for the
# server to accept the JWT.
VITE_AUTH0_AUDIENCE=https://lifeline-api
# OAuth scopes requested at login. Defaults to
# "openid profile email offline_access" when unset.
VITE_AUTH0_SCOPE=

# ── Local / compose auth bypass ──────────────────────────────────────────────
# Set to 1 to skip Auth0 entirely: the app acts authenticated as a fixed local
# user and sends the token "local-compose-token" (paired with AUTH_DISABLED=1
# on the server).
VITE_AUTH_DISABLED=
# Subject (user id) used in local auth mode. Defaults to "local-dev-user".
VITE_AUTH_LOCAL_SUB=

# ── Misc ─────────────────────────────────────────────────────────────────────
# Version string shown in the sidebar footer. Defaults to "1.0".
VITE_APP_VERSION=
# Dev-server proxy target for /api (read by vite.config.ts via process.env).
# Defaults to http://localhost:4000.
VITE_PROXY_TARGET=
