APP_PORT=3020

POSTGRES_DB=lifeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

PGSSL=0
PGSSL_ALLOW_SELF_SIGNED=1
DB_WAIT_TIMEOUT_MS=60000
DB_WAIT_INTERVAL_MS=2000
TYPEORM_LOGGING=0
LOG_LEVEL=info

# Local Compose verification defaults.
AUTH_DISABLED=1
AUTH_LOCAL_USER_ID=guest-local
VITE_AUTH_DISABLED=1
VITE_API_BASE_URL=/

# Enable these and provide real values to test Auth0-backed containers.
# Auth0 browser origins should use only the public app origins:
# - production: https://lifeline.a2z-us.com
# - local: http://localhost:3020
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_AUDIENCE_ALT=
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_SCOPE="openid profile email offline_access"

# Same-origin target used by the single-service app container.
CORS_ORIGIN=http://localhost:3020
FRONTEND_ORIGIN=http://localhost:3020
APP_ORIGIN=http://localhost:3020